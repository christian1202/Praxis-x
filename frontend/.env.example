# ============================================================
# Praxis Frontend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase project URL (found in Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=your-supabase-project-url-here

# Supabase publishable/anon key (NOT the service_role key)
# Found in Supabase Dashboard → Settings → API → Project API keys
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Auth server base URL
# Local development: http://localhost:3001
# Production: your auth server Render URL (or leave empty to use Vercel proxy)
VITE_AUTH_URL=http://localhost:3001