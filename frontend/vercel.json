{
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "https://praxis-auth-server.onrender.com/api/auth/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://praxis-backend-2w1i.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
