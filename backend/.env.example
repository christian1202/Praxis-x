# ============================================================
# Praxis Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase project URL (same as frontend)
SUPABASE_URL=your-supabase-project-url-here

# Supabase service_role key (JWT — KEEP THIS SECRET!)
# Found in Supabase Dashboard → Settings → API → Project API keys
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Auth server base URL
# Local development: http://localhost:3001
# Production: your auth server Render URL
AUTH_SERVER_URL=http://localhost:3001

# Frontend origin (for CORS)
# Local development: http://localhost:5173
# Production: your Vercel deployment URL
FRONTEND_URL=http://localhost:5173